# Copy to .env and fill in values before running docker compose up.

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AI_SIDECAR_SHARED_TOKEN=change-me-to-a-strong-random-value

# ── Chat / generation providers ───────────────────────────────────────────────
# Used by Metadata Enrichment, Mood Wizard, and Sequence Builder.
# Set any subset of keys you have. The fallback order is controlled by
# CHAT_PROVIDER_PRIORITY in compose.yaml (default: gemini,anthropic,openai,meta,ollama)
# — the first provider with a key set is tried first, and local Ollama is always
# the final fallback, so leaving every key blank uses Ollama only at zero cost.
#
# Google Gemini   — https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Anthropic Claude — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# OpenAI (also used for the optional cloud embedding fallback) — https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Meta Llama API (OpenAI-compatible) — https://llama.developer.meta.com
META_API_KEY=
